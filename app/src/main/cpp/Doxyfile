PROJECT_NAME           = "PaySmart Native Bridges"
PROJECT_BRIEF          = "JNI bridge and native crypto documentation"
OUTPUT_DIRECTORY       = ../../../../public/codedocs
CREATE_SUBDIRS         = NO
OUTPUT_LANGUAGE        = English

INPUT                  = native-lib.cpp \
                         room-lib.cpp \
                         crypto \
                         room \
                         ../java/net/metalbrain/paysmart/data/native
FILE_PATTERNS          = *.h *.hpp *.c *.cpp *.kt
RECURSIVE              = YES
EXCLUDE_PATTERNS       = */openssl/* */build/*

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
JAVADOC_AUTOBRIEF      = YES
OPTIMIZE_OUTPUT_JAVA   = YES

GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = NO
GENERATE_XML           = NO

SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

QUIET                  = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
