<?xml version="1.0" encoding="utf-8"?><!--
   Sample data extraction rules file; uncomment and customize as necessary.
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes
   for details.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="paysmart_secure_keys.xml" />
        <exclude domain="file" path="secure_password/" />
        <exclude domain="file" path="datastore/security_prefs.preferences_pb" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="paysmart_secure_keys.xml" />
        <exclude domain="file" path="secure_password/" />
        <exclude domain="file" path="datastore/security_prefs.preferences_pb" />
    </device-transfer>
</data-extraction-rules>
